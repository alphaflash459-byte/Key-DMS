rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. State synchronization matching rules (Zero-Trust access restricted per user)
    match /users/{userId}/state/{stateId} {
      allow read: if isOwner(userId) && isValidId(userId) && isValidId(stateId);
      allow create, update: if isOwner(userId) && isValidId(userId) && isValidId(stateId);
      allow delete: if isOwner(userId) && isValidId(userId) && isValidId(stateId);
    }
  }
}
